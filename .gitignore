# Project assets that should stay tracked:
# data/
# notebooks/
# requirements.txt

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and secrets
.env
.env.*

# Build and packaging artifacts
build/
dist/
*.egg-info/
*.egg
.eggs/

# Test, coverage, and lint caches
.tox/
.nox/
.pytest_cache/
.mypy_cache/
.pyre/
.cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Local logs and temp files
logs/
*.log
tmp/
temp/

# Database files created locally
*.sqlite3
*.db
*.db-journal

# IDE and editor settings
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Miscellaneous local history
.python_history
